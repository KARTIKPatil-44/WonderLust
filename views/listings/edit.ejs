<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>wonderlust</title>
</head>
<body>
    <h3>Edit your Listings</h3>
    <form method="POST" action="/listings/<%=listing._id %>?_method=PUT">
        <input type="text" name="listing[title]" value="<%= listing.title %>">
        <br><br>

        <textarea name="listing[description]"><%= listing.description %></textarea>
        <br><br>

        <input type="text" name="listing[image]" value="<%= listing.image || 'https://images.unsplash.com/photo-1584132967334-10e028bd69f7?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D' %>">

        <br><br>

        <input type="number" name="listing[price]" value="<%= listing.price %>">
        <br><br>

        <input type="text" name="listing[location]" value="<%= listing.location %>">
        <br><br>

        <input type="text" name="listing[country]" value="<%= listing.country %>">
        <br><br>

        <button>Edit</button>
    </form>
</body>
</html>
